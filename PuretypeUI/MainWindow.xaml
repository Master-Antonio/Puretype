<Window x:Class="PuretypeUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="PureType - Font Rendering Configuration"
        Height="720" Width="980" MinHeight="600" MinWidth="860"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/puretype_logo.png">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BrushBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- ══════ SIDEBAR ══════ -->
                <Border Grid.Column="0" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Image Source="Assets/puretype_logo.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,10,0"/>
                            <TextBlock Text="PureType" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,8,0,0">
                            <RadioButton x:Name="TabOverview" Style="{StaticResource SidebarTab}" IsChecked="True" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Overview" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabRendering" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Rendering" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabDisplay" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEDA1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Display" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabSystemFont" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="System Font" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabProfiles" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Profiles" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabAdvanced" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BE;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Advanced" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="16,10" Opacity="0.5"/>
                            <RadioButton x:Name="TabSettings" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabInfo" Style="{StaticResource SidebarTab}" Checked="Tab_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Width="22" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock Text="Info" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="12,0,12,12">
                            <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="4,0,4,10" Opacity="0.5"/>
                            <TextBlock x:Name="SidebarVersionText" FontSize="10" Foreground="{DynamicResource BrushTextSecondary}" Opacity="0.4" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- ══════ CONTENT ══════ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/><RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Style="{StaticResource BtnTitleBar}" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Click="Title_Minimize"/>
                            <Button Style="{StaticResource BtnTitleBar}" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Click="Title_Close" Tag="Close"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="24,0,24,0">
                        <Grid>
                            <!-- ═══ OVERVIEW ═══ -->
                            <StackPanel x:Name="PageOverview" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Live Preview" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>
                                        <Border Background="{DynamicResource BrushSurfaceVariant}" CornerRadius="6" Padding="24,20" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <Grid MinHeight="60">
                                                    <Image x:Name="PreviewImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                                    <TextBlock x:Name="PreviewFallback" Text="Preview not available — PureType.dll not found." FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,14,0,0">
                                                    <TextBlock Text="Standard AA" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="PureType Filtered" FontSize="11" Foreground="{DynamicResource BrushAccent}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="Quick Presets" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                                            <TextBlock Text="Apply tuned presets for your panel type." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,14"/>
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton x:Name="PresetBalancedButton" Content="Balanced" Style="{StaticResource QuickPresetChip}" Margin="0,0,6,0" Click="ApplyPreset_Click" Tag="balanced"/>
                                                <ToggleButton x:Name="PresetSharpButton" Content="Sharp" Style="{StaticResource QuickPresetChip}" Margin="0,0,6,0" Click="ApplyPreset_Click" Tag="sharp"/>
                                                <ToggleButton x:Name="PresetCleanButton" Content="Clean" Style="{StaticResource QuickPresetChip}" Margin="0,0,6,0" Click="ApplyPreset_Click" Tag="clean"/>
                                                <ToggleButton x:Name="PresetCustomButton" Content="Custom" Style="{StaticResource QuickPresetChip}" IsHitTestVisible="False" Focusable="False" ToolTip="Shown when the current values no longer match a preset."/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="Active Configuration" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                                            <Grid Margin="0,0,0,6"><TextBlock Text="Panel" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/><TextBlock x:Name="SummaryPanel" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Right"/></Grid>
                                            <Grid Margin="0,0,0,6"><TextBlock Text="Filter" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/><TextBlock x:Name="SummaryFilter" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Right"/></Grid>
                                            <Grid Margin="0,0,0,6"><TextBlock Text="Gamma" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/><TextBlock x:Name="SummaryGamma" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Right"/></Grid>
                                            <Grid><TextBlock Text="Stem Darkening" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/><TextBlock x:Name="SummaryStem" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Right"/></Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                            <!-- ═══ RENDERING ═══ -->
                            <StackPanel x:Name="PageRendering" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Panel &amp; Subpixel Filter" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>
                                        <TextBlock Text="Panel Type" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="PanelTypeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16" SelectionChanged="Setting_Changed_Combo">
                                            <ComboBoxItem Content="Samsung QD-OLED Gen 1/2" Tag="qd_oled_gen1"/>
                                            <ComboBoxItem Content="Samsung QD-OLED Gen 3" Tag="qd_oled_gen3" IsSelected="True"/>
                                            <ComboBoxItem Content="Samsung QD-OLED Gen 4" Tag="qd_oled_gen4"/>
                                            <ComboBoxItem Content="LG WOLED (R-W-B-G)" Tag="rwbg"/>
                                            <ComboBoxItem Content="LG WOLED (R-G-W-B)" Tag="rgwb"/>
                                        </ComboBox>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Filter Strength" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="FilterValText" Text="0.75" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="FilterStrengthSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="2" Value="0.75" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,16" ValueChanged="Setting_Changed_Slider"/>
                                        <StackPanel x:Name="WoledPanel">
                                            <Grid Margin="0,0,0,4"><TextBlock Text="WOLED Crosstalk Reduction" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="WoledValText" Text="0.08" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                            <Slider x:Name="WoledCrosstalkSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="0.5" Value="0.08" ValueChanged="Setting_Changed_Slider"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Gamma &amp; Tone Mapping" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>
                                        <TextBlock Text="Gamma Mode" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="GammaModeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16" SelectionChanged="Setting_Changed_Combo">
                                            <ComboBoxItem Content="Standard (sRGB)" Tag="srgb"/>
                                            <ComboBoxItem Content="OLED Softer" Tag="oled" IsSelected="True"/>
                                        </ComboBox>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Gamma Correction" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="GammaValText" Text="1.00" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="GammaSlider" Style="{StaticResource ModernSlider}" Minimum="0.5" Maximum="2.5" Value="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,16" ValueChanged="Setting_Changed_Slider"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="OLED Gamma Output" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="OledGammaValText" Text="1.00" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="OledGammaOutputSlider" Style="{StaticResource ModernSlider}" Minimum="1.0" Maximum="2.0" Value="1.0" Margin="0,0,0,16" ValueChanged="Setting_Changed_Slider"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Luma Contrast" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="LumaValText" Text="1.15" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="LumaContrastSlider" Style="{StaticResource ModernSlider}" Minimum="0.5" Maximum="2.0" Value="1.15" ValueChanged="Setting_Changed_Slider"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Hinting &amp; Stems" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>
                                        <CheckBox x:Name="SubpixelHintingCheck" Content="Subpixel Hinting" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,0,10" Click="Setting_Changed_Check"/>
                                        <CheckBox x:Name="FractionalPositioningCheck" Content="Fractional Positioning" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,0,14" Click="Setting_Changed_Check"/>
                                        <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="0,0,0,14" Opacity="0.3"/>
                                        <CheckBox x:Name="StemDarkeningCheck" Content="Stem Darkening" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,0,14" Click="StemDarkening_Changed"/>
                                        <StackPanel x:Name="StemStrengthPanel">
                                            <Grid Margin="0,0,0,4"><TextBlock Text="Stem Strength" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="StemStrValText" Text="0.25" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                            <Slider x:Name="StemStrengthSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="1" Value="0.25" ValueChanged="Setting_Changed_Slider"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- ═══ DISPLAY ═══ -->
                            <StackPanel x:Name="PageDisplay" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="LOD Thresholds" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                        <TextBlock Text="Glyph size thresholds (px) for level-of-detail filtering." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,14"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"><TextBlock Text="Small (px)" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/><Slider x:Name="LodSmallSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="50" Value="10" ValueChanged="LodSmall_Changed"/></StackPanel>
                                            <StackPanel Grid.Column="2"><TextBlock Text="Large (px)" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/><Slider x:Name="LodLargeSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" Value="22" ValueChanged="Setting_Changed_Slider"/></StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="High DPI Fade Thresholds" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                        <TextBlock Text="Above these PPI values, OLED filtering fades out and is eventually skipped." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,14"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"><TextBlock Text="Start Fade (PPI)" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/><Slider x:Name="HighDpiLowSlider" Style="{StaticResource ModernSlider}" Minimum="96" Maximum="300" Value="144" ValueChanged="DpiLow_Changed"/></StackPanel>
                                            <StackPanel Grid.Column="2"><TextBlock Text="Full Bypass (PPI)" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/><Slider x:Name="HighDpiHighSlider" Style="{StaticResource ModernSlider}" Minimum="96" Maximum="600" Value="216" ValueChanged="Setting_Changed_Slider"/></StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- ═══ SYSTEM FONT ═══ -->
                            <StackPanel x:Name="PageSystemFont" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Inter — OLED-Optimized System Font" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                        <TextBlock Text="Inter is a variable font designed for screens. Its weight and optical-size axes let you compensate for OLED subpixel quirks." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,18"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Button Content="Install Inter as System Font" Grid.Column="0" Style="{StaticResource BtnPrimary}" Padding="14,10" FontSize="13" HorizontalAlignment="Stretch" Click="InstallInterFont_Click"/>
                                            <Button Content="Restore Default Font" Grid.Column="2" Style="{StaticResource BtnBase}" Padding="14,10" FontSize="13" HorizontalAlignment="Stretch" Click="UninstallInterFont_Click"/>
                                        </Grid>
                                        <TextBlock x:Name="InterFontStatusText" Text="" FontSize="11" Foreground="{DynamicResource BrushSuccess}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Variable Font Axes" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="FontAxesHintText" Text="Adjust these axes to fine-tune Inter rendering for your OLED panel." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Font Weight" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="InterWeightValText" Text="400" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="InterWeightSlider" Style="{StaticResource ModernSlider}" Minimum="100" Maximum="900" Value="400" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,0,0,4" ValueChanged="InterAxis_Changed"/>
                                        <TextBlock x:Name="InterWeightHintText" FontSize="10.5" FontStyle="Italic" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Optical Size (opsz)" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="InterOpszValText" Text="18" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="InterOpszSlider" Style="{StaticResource ModernSlider}" Minimum="14" Maximum="32" Value="18" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,4" ValueChanged="InterAxis_Changed"/>
                                        <TextBlock x:Name="InterOpszHintText" FontSize="10.5" FontStyle="Italic" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Letter Spacing (px)" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="InterTrackingValText" Text="0.3" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="InterTrackingSlider" Style="{StaticResource ModernSlider}" Minimum="-2" Maximum="4" Value="0.3" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,4" ValueChanged="InterAxis_Changed"/>
                                        <TextBlock x:Name="InterTrackingHintText" FontSize="10.5" FontStyle="Italic" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                        <Button Content="Apply Recommended Values" Style="{StaticResource BtnBase}" Padding="14,8" FontSize="12" Click="ApplyRecommendedFontAxes_Click" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Preview" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                                        <Border Background="{DynamicResource BrushSurfaceVariant}" CornerRadius="6" Padding="20,16" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock x:Name="InterPreviewLarge" Text="The quick brown fox jumps over the lazy dog. 0123456789" FontSize="16" Foreground="{DynamicResource BrushTextPrimary}" TextWrapping="Wrap" LineHeight="26"/>
                                                <TextBlock x:Name="InterPreviewSmall" Text="ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz !@#$%^&amp;*()" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" LineHeight="20" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- ═══ PROFILES ═══ -->
                            <StackPanel x:Name="PageProfiles" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="Your Profiles" Style="{StaticResource SectionHeader}"/><Border x:Name="ProfileCountBadge" Background="{DynamicResource BrushAccent}" CornerRadius="10" Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center"><TextBlock x:Name="ProfileCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold"/></Border></StackPanel>
                                            <Border Background="{DynamicResource BrushSurfaceVariant}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Center"><TextBlock Text="Priority: App ▸ Monitor ▸ Global" FontSize="10" Foreground="{DynamicResource BrushTextSecondary}"/></Border>
                                        </Grid>
                                        <TextBlock Text="Profiles override global settings per-app or per-monitor." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                        <StackPanel x:Name="ProfilesContainer"/>
                                        <TextBlock x:Name="NoProfilesHint" Text="No custom profiles yet. Create one below." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" FontStyle="Italic" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Create New Profile" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{DynamicResource BrushSurfaceVariant}" CornerRadius="6" Padding="16,14" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10"><TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBlock Text="Monitor Profile" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/></StackPanel>
                                                    <TextBlock Text="Override rendering settings for a specific display." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                                    <ComboBox x:Name="DisplaysCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>
                                                    <Button Content="Create Monitor Profile" Style="{StaticResource BtnPrimary}" Padding="12,8" FontSize="12" HorizontalAlignment="Stretch" Click="CreateMonitorProfile_Click"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Background="{DynamicResource BrushSurfaceVariant}" CornerRadius="6" Padding="16,14" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10"><TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#2EA043" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBlock Text="Application Profile" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/></StackPanel>
                                                    <TextBlock Text="Create per-process overrides." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                                    <ComboBox x:Name="AppsCombo" Style="{StaticResource ModernComboBox}" IsEditable="True" Margin="0,0,0,10"/>
                                                    <Button Content="Create App Profile" Style="{StaticResource BtnPrimary}" Padding="12,8" FontSize="12" HorizontalAlignment="Stretch" Click="AddAppProfile_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ProfileEditCard" Style="{StaticResource Card}" Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal"><TextBlock x:Name="ProfileEditIcon" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBlock x:Name="ProfileEditTitle" Text="Edit Profile" Style="{StaticResource SectionHeader}"/></StackPanel>
                                            <Button Style="{StaticResource BtnGhost}" HorizontalAlignment="Right" Padding="8,4" Click="CloseProfileEdit_Click" ToolTip="Close editor"><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/></Button>
                                        </Grid>
                                        <TextBlock Text="Values set to '(Use Global)' inherit from global settings." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                        <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="0,0,0,16" Opacity="0.5"/>

                                        <TextBlock Text="Panel Type" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="ProfPanelTypeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,12"><ComboBoxItem Content="(Use Global)" Tag=""/><ComboBoxItem Content="Samsung QD-OLED Gen 1/2" Tag="qd_oled_gen1"/><ComboBoxItem Content="Samsung QD-OLED Gen 3" Tag="qd_oled_gen3"/><ComboBoxItem Content="Samsung QD-OLED Gen 4" Tag="qd_oled_gen4"/><ComboBoxItem Content="LG WOLED (R-W-B-G)" Tag="rwbg"/><ComboBoxItem Content="LG WOLED (R-G-W-B)" Tag="rgwb"/></ComboBox>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Filter Strength" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="ProfFilterValText" Text="—" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="ProfFilterSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="2" Value="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="ProfSlider_Changed"/>
                                        <TextBlock Text="Gamma Mode" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="ProfGammaModeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,12"><ComboBoxItem Content="(Use Global)" Tag=""/><ComboBoxItem Content="Standard (sRGB)" Tag="srgb"/><ComboBoxItem Content="OLED Softer" Tag="oled"/></ComboBox>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Gamma Correction" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="ProfGammaValText" Text="—" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="ProfGammaSlider" Style="{StaticResource ModernSlider}" Minimum="0.5" Maximum="2.5" Value="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="ProfSlider_Changed"/>
                                        <CheckBox x:Name="ProfStemDarkeningCheck" Content="Stem Darkening" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,0,12"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="Stem Strength" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="ProfStemStrValText" Text="—" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="ProfStemSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="1" Value="0.25" Margin="0,0,0,12" ValueChanged="ProfSlider_Changed"/>
                                        <Grid Margin="0,0,0,4"><TextBlock Text="WOLED Crosstalk Reduction" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="ProfWoledValText" Text="—" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="ProfWoledSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="0.5" Value="0.08" Margin="0,0,0,20" ValueChanged="ProfSlider_Changed"/>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource BtnPrimary}" Padding="14,8" FontSize="12" Click="SaveProfile_Click" Margin="0,0,8,0"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Save Profile" VerticalAlignment="Center"/></StackPanel></Button>
                                            <Button Style="{StaticResource BtnBase}" Padding="14,8" FontSize="12" Click="DeleteProfile_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/><TextBlock Text="Delete Profile" VerticalAlignment="Center"/></StackPanel></Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- ═══ ADVANCED ═══ -->
                            <StackPanel x:Name="PageAdvanced" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Advanced OLED Tuning" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                        <TextBlock Text="Fine tuning for QD expected separation and chroma keep scaling. These are global values." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                                        <Grid Margin="0,0,0,4"><TextBlock Text="QD Expected Separation Gen 1" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="QdSepGen1ValText" Text="-0.44" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="QdSepGen1Slider" Style="{StaticResource ModernSlider}" Minimum="-1.0" Maximum="-0.1" Value="-0.44" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="Setting_Changed_Slider"/>

                                        <Grid Margin="0,0,0,4"><TextBlock Text="QD Expected Separation Gen 3" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="QdSepGen3ValText" Text="-0.50" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="QdSepGen3Slider" Style="{StaticResource ModernSlider}" Minimum="-1.0" Maximum="-0.1" Value="-0.50" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="Setting_Changed_Slider"/>

                                        <Grid Margin="0,0,0,4"><TextBlock Text="QD Expected Separation Gen 4" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="QdSepGen4ValText" Text="-0.50" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="QdSepGen4Slider" Style="{StaticResource ModernSlider}" Minimum="-1.0" Maximum="-0.1" Value="-0.50" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="Setting_Changed_Slider"/>

                                        <Grid Margin="0,0,0,4"><TextBlock Text="QD Vertical Blend" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="QdVerticalBlendValText" Text="0.15" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="QdVerticalBlendSlider" Style="{StaticResource ModernSlider}" Minimum="0.0" Maximum="0.30" Value="0.15" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="Setting_Changed_Slider"/>

                                        <Grid Margin="0,0,0,4"><TextBlock Text="Chroma Keep Scale (QD)" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="ChromaKeepQdValText" Text="1.00" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="ChromaKeepQdSlider" Style="{StaticResource ModernSlider}" Minimum="0.60" Maximum="1.30" Value="1.00" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,12" ValueChanged="Setting_Changed_Slider"/>

                                        <Grid Margin="0,0,0,4"><TextBlock Text="Chroma Keep Scale (WOLED)" Style="{StaticResource FieldLabel}" Margin="0"/><TextBlock x:Name="ChromaKeepWoledValText" Text="1.00" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/></Grid>
                                        <Slider x:Name="ChromaKeepWoledSlider" Style="{StaticResource ModernSlider}" Minimum="0.60" Maximum="1.30" Value="1.00" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,16" ValueChanged="Setting_Changed_Slider"/>

                                        <Button Style="{StaticResource BtnBase}" Padding="14,8" FontSize="12" Click="ResetAdvancedDefaults_Click" HorizontalAlignment="Left">Reset Advanced Defaults</Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- ═══ SETTINGS ═══ -->
                            <StackPanel x:Name="PageSettings" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="System" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>
                                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Margin="0,0,0,10" IsChecked="False" Click="Setting_Changed_Check"/>
                                        <CheckBox x:Name="AutoCheckUpdatesCheck" Content="Auto-check for updates on startup" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,10" IsChecked="True" Click="Setting_Changed_Check"/>
                                        <CheckBox x:Name="DebugEnabledCheck" Content="Enhanced Logging" Margin="0,0,0,12" IsChecked="False" Click="Debug_Changed"/>
                                        <StackPanel x:Name="DebugOptionsPanel" Visibility="Collapsed">
                                            <CheckBox x:Name="HighlightGlyphsCheck" Content="Highlight Rendered Glyphs" Margin="0,0,0,10" Click="Setting_Changed_Check"/>
                                            <TextBlock Text="Log File" Style="{StaticResource FieldLabel}" Margin="0,4,0,6"/>
                                            <TextBox x:Name="LogFileText" Style="{StaticResource ModernTextBox}" Text="PURETYPE.log" Margin="0,0,0,12"/>
                                        </StackPanel>
                                        <TextBlock Text="Process Blacklist" Style="{StaticResource FieldLabel}" Margin="0,4,0,6"/>
                                        <TextBox x:Name="BlacklistText" Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" AcceptsReturn="True" Height="72" FontFamily="{DynamicResource FontMono}" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <!-- ═══ INFO ═══ -->
                            <StackPanel x:Name="PageInfo" Visibility="Collapsed" Margin="0,0,0,24">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Source="Assets/puretype_logo.png" Width="64" Height="64" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" Margin="0,8,0,16"/>
                                        <TextBlock x:Name="InfoVersionText" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="OLED-optimized font rendering for Windows" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                        <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="0,0,0,20" Opacity="0.4"/>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Author" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Toriga" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="GitHub" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Hyperlink NavigateUri="https://github.com/Master-Antonio" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource BrushAccent}" TextDecorations="None">
                                                    github.com/Master-Antonio
                                                </Hyperlink>
                                            </TextBlock>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Donate" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Hyperlink NavigateUri="https://paypal.me/masterantonio" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource BrushAccent}" TextDecorations="None">
                                                    paypal.me/masterantonio
                                                </Hyperlink>
                                            </TextBlock>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Version" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="InfoVersionValue" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <!-- ── UPDATE CARD ── -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Updates" Style="{StaticResource SectionHeader}"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Status: checking / up to date / error -->
                                        <TextBlock x:Name="UpdateStatusText" Text="Click the button below to check for updates." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                        <!-- Update available banner (hidden by default) -->
                                        <Border x:Name="UpdateAvailableBanner" Visibility="Collapsed" Background="#1A2EA043" CornerRadius="6" Padding="14,10" Margin="0,0,0,12" BorderBrush="#2EA043" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2EA043" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock x:Name="UpdateVersionText" Text="" FontSize="13" FontWeight="SemiBold" Foreground="#2EA043" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="UpdateSizeText" Text="" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                                <TextBlock x:Name="UpdateNotesText" Text="" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" MaxHeight="80" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Progress bar (hidden by default) -->
                                        <StackPanel x:Name="UpdateProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                                            <TextBlock x:Name="UpdateProgressText" Text="Downloading..." FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,6"/>
                                            <Border Background="{DynamicResource BrushBorder}" CornerRadius="3" Height="6">
                                                <Border x:Name="UpdateProgressBar" Background="{DynamicResource BrushAccent}" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                                            </Border>
                                        </StackPanel>
                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="CheckUpdateBtn" Style="{StaticResource BtnBase}" Padding="14,8" FontSize="12" Click="CheckForUpdates_Click" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Check for Updates" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="DownloadUpdateBtn" Style="{StaticResource BtnPrimary}" Padding="14,8" FontSize="12" Click="DownloadUpdate_Click" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Download &amp; Install" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="ViewReleaseBtn" Style="{StaticResource BtnGhost}" Padding="10,8" FontSize="12" Click="ViewReleasePage_Click" Visibility="Collapsed" ToolTip="Open release page on GitHub">
                                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="License" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                                        <TextBlock Text="This software is open source. See the LICENSE file for details." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
            <!-- ══════ STATUS BAR ══════ -->
            <Border Grid.Row="1" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
                <Grid Margin="10,0">
                    <TextBlock x:Name="StatusConfigText" Text="Ready" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="GlobalSaveBtn" Style="{StaticResource BtnPrimary}" FontSize="11" Padding="14,4" Click="Save_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Save &amp; Apply" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
